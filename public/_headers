/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; img-src 'self' res.cloudinary.com images.unsplash.com data:; script-src 'self' 'unsafe-inline' 'unsafe-eval' www.clarity.ms static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com; font-src fonts.gstatic.com; connect-src 'self' formspree.io raw.githubusercontent.com api.open-meteo.com *.clarity.ms c.bing.com cloudflareinsights.com; frame-ancestors 'none'

# 静的アセット (Next.js _next/) は長期キャッシュ
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# HTML はやや短め (rebuild 時に新版を素早く配信)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Sitemap/Feed は中程度キャッシュ
/sitemap*.xml
  Cache-Control: public, max-age=3600
/feed.xml
  Cache-Control: public, max-age=3600
